@@ -0,0 +1,62 @@
+import {
+  Button,
+  HStack,
+  Input,
+  Modal,
+  ModalBody,
+  ModalCloseButton,
+  ModalContent,
+  ModalHeader,
+  ModalOverlay,
+  Text,
+  VStack,
+} from "@chakra-ui/react";
+import { FC, useEffect, useState } from "react";
+import CopyToClipboard from "react-copy-to-clipboard";
+
+const rows = (base: string): [string, string][] => [
+  ["自动识别订阅", base],
+  ["Clash/Mihomo", `${base}/clash-meta`],
+  ["Clash/Mihomo 全量调试", `${base}/clash-meta-full`],
+  ["Egern", `${base}/egern`],
+  ["Shadowrocket", `${base}/shadowrocket`],
+  ["sing-box", `${base}/sing-box`],
+  ["通用节点订阅", base],
+  ["v2ray-json", `${base}/v2ray-json`],
+];
+
+export const LinkRaySubscriptionLinks: FC = () => {
+  const [base, setBase] = useState<string | null>(null);
+
+  useEffect(() => {
+    window.linkrayShowSubscriptionLinks = (value: string) => setBase(value);
+  }, []);
+
+  return (
+    <Modal isOpen={!!base} onClose={() => setBase(null)} size="4xl">
+      <ModalOverlay />
+      <ModalContent>
+        <ModalHeader>客户端订阅链接</ModalHeader>
+        <ModalCloseButton />
+        <ModalBody pb={8}>
+          <VStack alignItems="stretch" spacing={3}>
+            {base && rows(base).map(([label, url]) => (
+              <HStack key={label}>
+                <Text minW="140px" fontWeight="bold">{label}</Text>
+                <Input value={url} isReadOnly />
+                <CopyToClipboard text={url}>
+                  <Button colorScheme="primary">复制</Button>
+                </CopyToClipboard>
+              </HStack>
+            ))}
+          </VStack>
+        </ModalBody>
+      </ModalContent>
+    </Modal>
+  );
+};
+
+declare global {
+  interface Window {
+    linkrayShowSubscriptionLinks?: (base: string) => void;
+  }
+}
